# MarTech Audit Tool — API Keys
# Metodo consigliato: variabili d'ambiente (export CLAUDE_API_KEY=...)
# Alternativa: copia questo file in .env e inserisci le chiavi:
#   cp .env.example .env

CLAUDE_API_KEY=your-claude-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Opzionale: proteggi gli endpoint proxy del web server con un token
# AUDIT_API_TOKEN=your-random-token-here
